---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const title = 'Page Not Found | emoj.ie';
const description = 'The page you were looking for could not be found.';
const canonicalUrl = 'https://emoj.ie/404/';
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  noindex={true}
  bodyClass="page-404"
>
  <Header />

  <main id="main-content" class="page-main">
    <section class="panel-shell">
      <div class="not-found-content">
        <span class="not-found-emoji" aria-hidden="true">&#x1F615;</span>
        <h1>Page not found</h1>
        <p>
          We couldn't find what you were looking for. It may have moved or no longer exists.
        </p>
        <a href="/" class="copy-btn">Go back home</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found-content {
    text-align: center;
    display: grid;
    gap: 0.75rem;
    justify-items: center;
    padding: 2rem 0;
  }

  .not-found-emoji {
    font-size: 4rem;
    line-height: 1;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }

  p {
    margin: 0;
    max-width: 42ch;
    color: var(--text-body);
    font-size: 1.05rem;
  }
</style>
