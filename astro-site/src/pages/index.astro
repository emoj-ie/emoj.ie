---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import EmojiImage from '../components/layout/EmojiImage.astro';
import { loadEmojiModel } from '../lib/data/load-emoji';
import { organizationSchema, websiteSchema } from '../lib/utils/seo';
import { humanize } from '../lib/utils/copy-formats';

const model = await loadEmojiModel();

// Browsable categories exclude component, extras-openmoji, extras-unicode
const EXCLUDED_HOME_GROUPS = new Set(['component', 'extras-openmoji', 'extras-unicode']);

const browsableCategories = model.categories
  .filter((cat) => !EXCLUDED_HOME_GROUPS.has(cat.key))
  .map((cat) => {
    // Pick a few representative emojis for the card preview
    const allNonVariant = cat.subgroups
      .flatMap((sg) => sg.emojis)
      .filter((e) => !e.isVariant);
    const previewEmojis = allNonVariant.slice(0, 6);

    return {
      key: cat.key,
      title: cat.title,
      description: cat.description,
      route: cat.route,
      previewEmojis,
      totalCount: allNonVariant.length,
    };
  });

const title = 'Search, Copy, And Explore Emojis | emoj.ie';
const description =
  'Search emojis by category, copy in multiple formats, and jump to detailed pages.';
const canonicalUrl = 'https://emoj.ie/';

const jsonLd = [organizationSchema(), websiteSchema()];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  bodyClass="page-home"
>
  <Header />

  <main id="main-content" class="page-main">
    <section class="panel-shell home-emoji-shell" aria-label="Emoji Explorer">
      <h1 class="visually-hidden">Emoji Categories</h1>
      <div class="panel-grid" data-level="group">
        {browsableCategories.map((cat) => (
          <a class="panel-card panel-card-link" href={cat.route} aria-label={`Open ${humanize(cat.key)}`}>
            <span class="panel-card-title">{cat.previewEmojis[0] ? cat.previewEmojis[0].emoji : ''} {humanize(cat.key)}</span>
            <span class="panel-card-hero" aria-hidden="true">
              {cat.previewEmojis[0] && (
                <EmojiImage
                  hex={cat.previewEmojis[0].assetHex}
                  annotation={cat.previewEmojis[0].annotation}
                  size={56}
                  useLocal={cat.previewEmojis[0].useLocalAsset}
                  emoji={cat.previewEmojis[0].emoji}
                />
              )}
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

