---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import EmojiImage from '../../components/layout/EmojiImage.astro';
import { loadEmojiModel } from '../../lib/data/load-emoji';
import {
  organizationSchema,
  categoryPageSchema,
} from '../../lib/utils/seo';
import { humanize } from '../../lib/utils/copy-formats';

import type { Category, EmojiEntry } from '../../lib/data/types';

interface SlicedSubgroup {
  key: string;
  title: string;
  route: string;
  noindex: boolean;
  description: string;
  previewEmojis: EmojiEntry[];
  totalCount: number;
}

interface Props {
  category: {
    key: string;
    title: string;
    route: string;
    noindex: boolean;
    description: string;
  };
  subgroups: SlicedSubgroup[];
}

export async function getStaticPaths() {
  const model = await loadEmojiModel();

  return model.categories.map((category) => {
    // ARCH-05: Slice data at build time -- pass only preview emojis per subgroup
    const subgroups: SlicedSubgroup[] = category.subgroups.map((sg) => {
      const nonVariant = sg.emojis.filter((e) => !e.isVariant);
      return {
        key: sg.key,
        title: sg.title,
        route: `/${category.key}/${sg.key}/`,
        noindex: sg.noindex,
        description: sg.description,
        previewEmojis: nonVariant.slice(0, 24),
        totalCount: nonVariant.length,
      };
    });

    return {
      params: { category: category.key },
      props: {
        category: {
          key: category.key,
          title: category.title,
          route: category.route,
          noindex: category.noindex,
          description: category.description,
        },
        subgroups,
      },
    };
  });
}

const { category, subgroups } = Astro.props;

const SITE_URL = 'https://emoj.ie';
const categoryTitle = humanize(category.key);
const title = `${categoryTitle} Emojis | emoj.ie`;
const description = category.description;
const canonicalUrl = `${SITE_URL}${category.route}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: categoryTitle },
];

// Breadcrumb JSON-LD is rendered by the Breadcrumbs component
const jsonLd = [
  organizationSchema(),
  categoryPageSchema(category),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  noindex={category.noindex}
  jsonLd={jsonLd}
  bodyClass="page-group"
>
  <Header />
  <Breadcrumbs items={breadcrumbItems} />

  <main id="main-content" class="page-main">
    <section class="group">
      <h1>{categoryTitle} Emojis</h1>
      <p class="subgroup-meta">{description}</p>

      <ul class="group-link-list">
        {subgroups.map((sg) => (
          <li>
            <a href={sg.route}>
              <span>{humanize(sg.key)}</span>
              <small>{sg.totalCount} emojis</small>
            </a>
          </li>
        ))}
      </ul>

      {subgroups.map((sg) => (
        <section class="subgroup">
          <h2>
            <a href={sg.route}>{humanize(sg.key)}</a>
          </h2>
          <p class="subgroup-meta">
            {sg.totalCount} emojis
          </p>
          <div class="panel-grid">
            {sg.previewEmojis.map((emoji) => (
              <a href={emoji.detailRoute} class="panel-card" title={emoji.annotation}>
                <div class="panel-card-hero">
                  <EmojiImage
                    hex={emoji.assetHex}
                    annotation={emoji.annotation}
                    size={72}
                    useLocal={emoji.useLocalAsset}
                    emoji={emoji.emoji}
                  />
                </div>
                <span class="panel-card-title">{emoji.annotation}</span>
              </a>
            ))}
          </div>
          {sg.totalCount > sg.previewEmojis.length && (
            <p>
              <a href={sg.route} class="emoji-empty-link">
                View all {sg.totalCount} {humanize(sg.key)} emojis
              </a>
            </p>
          )}
        </section>
      ))}
    </section>
  </main>

  <Footer />
</BaseLayout>
