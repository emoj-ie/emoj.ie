---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import EmojiImage from '../../components/layout/EmojiImage.astro';
import { loadEmojiModel } from '../../lib/data/load-emoji';
import {
  organizationSchema,
  categoryPageSchema,
} from '../../lib/utils/seo';
import { humanize } from '../../lib/utils/copy-formats';

import type { Category, EmojiEntry } from '../../lib/data/types';

interface SlicedSubgroup {
  key: string;
  title: string;
  route: string;
  noindex: boolean;
  description: string;
  previewEmojis: EmojiEntry[];
  totalCount: number;
}

interface Props {
  category: {
    key: string;
    title: string;
    route: string;
    noindex: boolean;
    description: string;
  };
  subgroups: SlicedSubgroup[];
}

export async function getStaticPaths() {
  const model = await loadEmojiModel();

  return model.categories.map((category) => {
    // ARCH-05: Slice data at build time -- pass only preview emojis per subgroup
    const subgroups: SlicedSubgroup[] = category.subgroups.map((sg) => {
      const nonVariant = sg.emojis.filter((e) => !e.isVariant);
      return {
        key: sg.key,
        title: sg.title,
        route: `/${category.key}/${sg.key}/`,
        noindex: sg.noindex,
        description: sg.description,
        previewEmojis: nonVariant.slice(0, 24),
        totalCount: nonVariant.length,
      };
    });

    return {
      params: { category: category.key },
      props: {
        category: {
          key: category.key,
          title: category.title,
          route: category.route,
          noindex: category.noindex,
          description: category.description,
        },
        subgroups,
      },
    };
  });
}

const { category, subgroups } = Astro.props;

const SITE_URL = 'https://emoj.ie';
const categoryTitle = humanize(category.key);
const title = `${categoryTitle} Emojis | emoj.ie`;
const description = category.description;
const canonicalUrl = `${SITE_URL}${category.route}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: categoryTitle },
];

// Breadcrumb JSON-LD is rendered by the Breadcrumbs component
const jsonLd = [
  organizationSchema(),
  categoryPageSchema(category),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  noindex={category.noindex}
  jsonLd={jsonLd}
  bodyClass="page-group"
>
  <Header />
  <Breadcrumbs items={breadcrumbItems} />

  <main id="main-content" class="page-main">
    <section class="panel-shell home-emoji-shell">
      <h1 class="visually-hidden">{categoryTitle}</h1>
      <div class="panel-grid panel-grid-balanced">
        {subgroups.map((sg) => (
          <a class="panel-card panel-card-link" href={sg.route} aria-label={`Open ${humanize(sg.key)}`}>
            <span class="panel-card-title">{sg.previewEmojis[0] ? sg.previewEmojis[0].emoji : ''} {humanize(sg.key)}</span>
            <span class="panel-card-hero" aria-hidden="true">
              {sg.previewEmojis[0] && (
                <EmojiImage
                  hex={sg.previewEmojis[0].assetHex}
                  annotation={sg.previewEmojis[0].annotation}
                  size={56}
                  useLocal={sg.previewEmojis[0].useLocalAsset}
                  emoji={sg.previewEmojis[0].emoji}
                />
              )}
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
