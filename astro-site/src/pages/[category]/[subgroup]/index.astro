---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro';
import EmojiGrid from '../../../components/islands/EmojiGrid.svelte';
import { loadEmojiModel } from '../../../lib/data/load-emoji';
import { organizationSchema } from '../../../lib/utils/seo';
import { humanize } from '../../../lib/utils/copy-formats';

import type { EmojiEntry } from '../../../lib/data/types';

interface Props {
  subgroup: {
    key: string;
    title: string;
    route: string;
    noindex: boolean;
    description: string;
    emojis: EmojiEntry[];
  };
  parentCategory: {
    key: string;
    title: string;
    route: string;
  };
}

export async function getStaticPaths() {
  const model = await loadEmojiModel();

  const paths: {
    params: { category: string; subgroup: string };
    props: Props;
  }[] = [];

  for (const category of model.categories) {
    for (const sg of category.subgroups) {
      // ARCH-05: Pass only non-variant emojis for this subgroup
      const nonVariantEmojis = sg.emojis.filter((e) => !e.isVariant);

      paths.push({
        params: {
          category: category.key,
          subgroup: sg.key,
        },
        props: {
          subgroup: {
            key: sg.key,
            title: sg.title,
            route: `/${category.key}/${sg.key}/`,
            noindex: sg.noindex,
            description: sg.description,
            emojis: nonVariantEmojis,
          },
          parentCategory: {
            key: category.key,
            title: category.title,
            route: category.route,
          },
        },
      });
    }
  }

  return paths;
}

const { subgroup, parentCategory } = Astro.props;

const SITE_URL = 'https://emoj.ie';
const categoryTitle = humanize(parentCategory.key);
const subgroupTitle = humanize(subgroup.key);
const title = `${subgroupTitle} Emojis | ${categoryTitle} | emoj.ie`;
const description = subgroup.description;
const canonicalUrl = `${SITE_URL}${subgroup.route}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: categoryTitle, href: parentCategory.route },
  { label: subgroupTitle },
];

// Breadcrumb JSON-LD is rendered by the Breadcrumbs component
const jsonLd = [
  organizationSchema(),
];

// Serialize emoji data for the Svelte island (only needed fields)
const gridEmojis = subgroup.emojis.map((e) => ({
  annotation: e.annotation,
  emoji: e.emoji,
  hexLower: e.hexLower,
  assetHex: e.assetHex,
  detailRoute: e.detailRoute,
  useLocalAsset: e.useLocalAsset,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  noindex={subgroup.noindex}
  jsonLd={jsonLd}
  bodyClass="page-subgroup"
>
  <Header />
  <Breadcrumbs items={breadcrumbItems} />

  <main id="main-content" class="page-main">
    <section class="subgroup">
      <h1 class="visually-hidden">{subgroupTitle} Emojis</h1>
      <EmojiGrid client:visible emojis={gridEmojis} />
    </section>
  </main>

  <Footer />
</BaseLayout>
