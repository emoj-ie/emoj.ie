---
/**
 * Site header with logo badge, wordmark, Search island, and ThemeSwitcher.
 * All interactive features are Svelte islands -- no vanilla JS.
 */
import Search from '../islands/Search.svelte';
import ThemeSwitcher from '../islands/ThemeSwitcher.svelte';
---

<a href="#main-content" class="skip-link">Skip To Main Content</a>

<header class="header">
  <div class="header-container">
    <a href="/" class="logo" aria-label="emoj.ie home">
      <span class="logo-badge">
        <img
          class="logo-emoji"
          src="/assets/emoji/base/1F600.svg"
          alt=""
          width="26"
          height="26"
        />
        <span class="logo-emoji-fallback" aria-hidden="true"></span>
      </span>
      <span class="logo-wordmark">emoj.ie</span>
    </a>

    <Search client:load />
    <ThemeSwitcher client:load />
  </div>
</header>
