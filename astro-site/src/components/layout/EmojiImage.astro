---
/**
 * Renders an emoji SVG image with CDN fallback.
 *
 * Props:
 *   hex        - Uppercase hex code for the emoji (e.g. "1F600")
 *   annotation - Alt text for the image
 *   size       - Width and height in pixels (default 72)
 *   useLocal   - Use local asset path; falls back to CDN when false (default true)
 *   loading    - Image loading strategy: "lazy" (default) or "eager"
 *   emoji      - Native emoji character for hidden fallback text
 */
interface Props {
  hex: string;
  annotation: string;
  size?: number;
  useLocal?: boolean;
  loading?: 'lazy' | 'eager';
  emoji?: string;
}

const {
  hex,
  annotation,
  size = 72,
  useLocal = true,
  loading = 'lazy',
  emoji,
} = Astro.props;

const upperHex = hex.toUpperCase();
const localSrc = `/assets/emoji/base/${upperHex}.svg`;
const cdnSrc = `https://cdn.jsdelivr.net/npm/openmoji@15.1.0/color/svg/${upperHex}.svg`;

const src = useLocal ? localSrc : cdnSrc;
const fallbackSrc = useLocal ? cdnSrc : localSrc;
---

<span class="emoji-image-wrap">
  <img
    src={src}
    alt={annotation}
    width={size}
    height={size}
    loading={loading}
    decoding="async"
    data-cdn-src={cdnSrc}
  />
  {emoji && <span class="emoji-image-fallback" aria-hidden="true">{emoji}</span>}
</span>

<style>
  .emoji-image-wrap {
    display: inline-grid;
    place-items: center;
    position: relative;
  }

  img {
    object-fit: contain;
    display: block;
  }

  .emoji-image-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2rem;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
  }
</style>
